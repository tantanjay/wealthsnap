{
  "expo": {
    "name": "WealthSnap",
    "slug": "WealthSnap",
    "version": "1.14.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "WealthSnap uses FaceID to unlock your locally stored financial dashboard. Your biometric data never leaves your device and is not accessible by the developer."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0033CC"
      },
      "package": "com.christian.soyosa.WealthSnap",
      "versionCode": 24,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/ef38c9a6-19b2-4532-8ec8-f1b68e09dac1",
      "enableBsdiffPatchSupport": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to scan receipts.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan receipts."
        }
      ],
      [
        "expo-navigation-bar"
      ],
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-local-authentication",
      "expo-notifications",
      "expo-background-task",
      "expo-document-picker",
      "expo-task-manager",
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "react-native-document-scanner-plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "ef38c9a6-19b2-4532-8ec8-f1b68e09dac1"
      },
      "expo-navigation-bar": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
